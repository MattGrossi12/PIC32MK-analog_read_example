{
    "version": "1.8",
    "importedFrom": "./",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "PIC32MK0128MCA048",
            "imageType": "application",
            "imagePath": "./out/PIC32MK-analog_read_example/default.elf",
            "tool": "pkob4hybrid",
            "packs": [
                {
                    "name": "PIC32MK-MC_DFP",
                    "vendor": "Microchip",
                    "version": "1.12.263"
                }
            ],
            "fileSet": "Project files",
            "toolchain": "default-XC32"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC32",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc32@5.00",
            "properties": {
                "compiler.additional-warnings": true,
                "compiler.addresss-attribute-use": false,
                "compiler.cast-align": false,
                "compiler.code-model": "default",
                "compiler.const-model": "default",
                "compiler.data-model": "default",
                "compiler.disable-instruction-scheduling": false,
                "compiler.enable-app-io": false,
                "compiler.enable-omit-frame-pointer": false,
                "compiler.enable-procedural-abstraction": false,
                "compiler.enable-short-double": false,
                "compiler.enable-symbols": true,
                "compiler.enable-unroll-loops": false,
                "compiler.exclude-floating-point": false,
                "compiler.expand-pragma-config": false,
                "compiler.extra-include-directories": ".",
                "compiler.generate-16-bit-code": false,
                "compiler.generate-micro-compressed-code": false,
                "compiler.isolate-each-function": true,
                "compiler.keep-inline": false,
                "compiler.make-warnings-into-errors": true,
                "compiler.oXC16gcc-large-aggregate": false,
                "compiler.oXC16gcc-near-chars": false,
                "compiler.oXC16gcc-no-isr-warn": false,
                "compiler.oXC16gcc-sfr-warn": false,
                "compiler.oXC16gcc-smar-io-lvl": "1",
                "compiler.optimization-level": "-O1",
                "compiler.place-data-into-section": true,
                "compiler.post-instruction-scheduling": "default",
                "compiler.pre-instruction-scheduling": "default",
                "compiler.scalar-model": "default",
                "compiler.strict-ansi": false,
                "compiler.support-ansi": false,
                "compiler.tentative-definitions": "-fno-common",
                "compiler.use-cci": false,
                "compiler.use-iar": false,
                "compiler.use-indirect-calls": false,
                "compiler++.additional-warnings": false,
                "compiler++.addresss-attribute-use": false,
                "compiler++.check-new": false,
                "compiler++.eh-specs": true,
                "compiler++.enable-app-io": false,
                "compiler++.enable-omit-frame-pointer": false,
                "compiler++.enable-symbols": true,
                "compiler++.enable-unroll-loops": false,
                "compiler++.exceptions": true,
                "compiler++.exclude-floating-point": false,
                "compiler++.extra-include-directories": ".",
                "compiler++.generate-16-bit-code": false,
                "compiler++.generate-micro-compressed-code": false,
                "compiler++.isolate-each-function": true,
                "compiler++.make-warnings-into-errors": false,
                "compiler++.optimization-level": "-O1",
                "compiler++.place-data-into-section": false,
                "compiler++.post-instruction-scheduling": "default",
                "compiler++.pre-instruction-scheduling": "default",
                "compiler++.rtti": true,
                "compiler++.strict-ansi": false,
                "compiler++.use-cci": false,
                "compiler++.use-iar": false,
                "compiler++.use-indirect-calls": false,
                "assembler.enable-symbols": true,
                "assembler.exclude-floating-point-library": false,
                "assembler.expand-macros": false,
                "assembler.extra-include-directories-for-assembler": ".",
                "assembler.extra-include-directories-for-preprocessor": ".",
                "assembler.false-conditionals": false,
                "assembler.generate-16-bit-code": false,
                "assembler.generate-micro-compressed-code": false,
                "assembler.keep-locals": false,
                "assembler.list-assembly": false,
                "assembler.list-section-info": false,
                "assembler.list-source": false,
                "assembler.list-symbols": false,
                "assembler.oXC32asm-list-to-file": false,
                "assembler.omit-debug-dirs": false,
                "assembler.omit-forms": false,
                "assembler.relax": false,
                "archiver.additional-options-chop-files": false,
                "linker.additional-options-use-response-files": false,
                "linker.additional-options-write-sla": false,
                "linker.allocate-dinit": false,
                "linker.code-dinit": false,
                "linker.enable-check-sections": false,
                "linker.enable-data-init": true,
                "linker.enable-default-isr": true,
                "linker.exclude-floating-point-library": false,
                "linker.exclude-standard-libraries": false,
                "linker.extra-lib-directories": ".",
                "linker.fill-flash-options-how": "0",
                "linker.fill-flash-options-inc-const": "1",
                "linker.fill-flash-options-what": "0",
                "linker.generate-16-bit-code": false,
                "linker.generate-cross-reference-file": false,
                "linker.generate-micro-compressed-code": false,
                "linker.heap-size": "0",
                "linker.no-device-startup-code": false,
                "linker.no-ivt": false,
                "linker.no-startup-files": false,
                "linker.oXC16ld-force-link": false,
                "linker.oXC16ld-no-smart-io": false,
                "linker.oXC16ld-stackguard": "16",
                "linker.remove-unused-sections": true,
                "linker.report-memory-usage": false,
                "linker.warn-section-align": false,
                "coverage.stack-guidance": false,
                "global.combine-sourcefiles": false,
                "global.dual-boot-partition": "0",
                "global.generic-16-bit": false,
                "global.legacy-libc": true,
                "global.mpreserve-all": false,
                "global.mstacktcm": false,
                "global.omit-pack-options": "1",
                "global.preserve-all": false,
                "global.relaxed-math": false,
                "global.save-temps": false,
                "global.wpo-lto": false
            }
        }
    ],
    "fileSets": [
        {
            "name": "Project files",
            "files": [
                "Makefile",
                "src/*",
                "*.mc3"
            ],
            "encoding": "ISO-8859-1"
        }
    ]
}
